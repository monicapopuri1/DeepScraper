# Copy this file to .env and fill in your values
# Never commit .env to git

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use for course verification and contact extraction
# claude-haiku-4-5-20251001  → faster and cheaper (~$0.01 per college)
# claude-sonnet-4-6          → more accurate (~$0.05 per college)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Number of colleges to process in parallel (3 is recommended)
# Higher = faster, but risks getting rate-limited by college websites
MAX_WORKERS=3

# Ollama settings (only needed if falling back to local LLM)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

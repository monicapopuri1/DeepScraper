# College Mention Crawler API Configuration

# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# Crawler defaults
DEFAULT_MAX_DEPTH=3
DEFAULT_MAX_PAGES=100
DEFAULT_TIMEOUT_SECONDS=120
CRAWLER_CONCURRENCY=10
CRAWLER_DELAY=0.25

# College Scorecard API (optional - enables enrichment)
# Get a free key at: https://api.data.gov/signup/
# COLLEGE_SCORECARD_API_KEY=your_key_here
